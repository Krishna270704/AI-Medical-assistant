# Railway Deployment Environment Variables

# The secret key for securely signing the session cookie
SECRET_KEY=your_secure_random_secret_key_here

# Database URL for SQLite (or change for other databases if used)
DATABASE_URL=sqlite:///../database/chat_history.db

# LLM Provider configuration (nvidia)
LLM_PROVIDER=nvidia
MODEL_NAME=nvidia/nemotron-3-ultra-550b-a55b

# NVIDIA NIM API Key (required for LLM inferences)
NVIDIA_API_KEY=your_nvidia_api_key_here

# HuggingFace API token (if using local embeddings or certain HF models)
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here

# Port to bind the server to (Railway will automatically inject this)
PORT=5000
